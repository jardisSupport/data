{
  "name": "jardissupport/data",
  "description": "Entity Data Service for PHP - Hydration, Change Tracking, Snapshots",
  "version": "1.0.0",
  "type": "library",
  "license": "PolyForm-Noncommercial-1.0.0",
  "minimum-stability": "stable",
  "prefer-stable": true,
  "authors": [
    {
      "name": "Jardis Development",
      "email": "jardisDev@headgent.com"
    }
  ],
  "require": {
    "php": ">=8.2",
"ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "phpstan/phpstan": "^2.0.4",
    "squizlabs/php_codesniffer": "^3.11.2 || ^4.0.0"
  },
  "autoload": {
    "psr-4": {
      "JardisSupport\\Data\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "JardisSupport\\Data\\Tests\\": "tests/"
    }
  },
  "homepage": "https://github.com/jardisSupport/data",
  "support": {
    "issues": "https://github.com/jardisSupport/data/issues",
    "email": "jardisDev@headgent.com"
  },
  "keywords": ["data", "entity", "hydration", "change-tracking", "snapshot", "jardis", "Headgent"]
}
